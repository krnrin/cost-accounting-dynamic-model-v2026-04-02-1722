# =============================================
# 飞书集成配置 (Feishu/Lark Integration)
# =============================================
# 复制此文件为 .env.local 并填入你的飞书应用配置
# cp .env.local.example .env.local

# 飞书应用凭证 (在飞书开放平台 → 应用详情 → 凭证与基础信息)
VITE_FEISHU_APP_ID=
VITE_FEISHU_APP_SECRET=

# 飞书多维表格配置 (创建多维表格后获取)
# App Token: 多维表格 URL 中 /base/ 后面的部分
VITE_BITABLE_APP_TOKEN=
# 各数据表 Table ID: 点击表的「...」→「复制链接」→ URL 中 table= 后面的部分
VITE_BITABLE_TABLE_PROJECTS=
VITE_BITABLE_TABLE_HARNESSES=
VITE_BITABLE_TABLE_QUOTES=
VITE_BITABLE_TABLE_VERSIONS=
VITE_BITABLE_TABLE_AUDIT_LOGS=

# =============================================
# 后端 API 配置 (仅离线模式 + Express 后端时需要)
# =============================================
# VITE_API_URL=http://localhost:3001/api
