generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("ENGINEER") // ADMIN, MANAGER, ENGINEER, VIEWER
  feishuId      String?  @unique
  tokenVersion  Int      @default(0) // [PR-003] JWT撤销机制：角色变更时递增
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects   Project[]
  auditLogs  AuditLog[]
}

model Project {
  id          String   @id @default(uuid())
  projectCode String   @unique
  projectName String
  customer    String
  platform    String?
  status      String   @default("active")

  costRates   String   @default("{}") // JSON string
  metalPrices String   @default("{}") // JSON string
  volumes     String?

  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scenarios   Scenario[]
  harnesses   Harness[]
  quotes      Quote[]
  allocations AllocationItem[]
  simulations SimulationTask[]
  versions    Version[]
  auditLogs   AuditLog[]
  connectorPricings ConnectorPricing[]
  wirePricings WirePricing[]
  devPartPricings DevPartPricing[]
  auxiliaryPricings AuxiliaryPricing[]
  priceDiscrepancies PriceDiscrepancy[]
}

model Scenario {
  id                  String           @id @default(uuid())
  projectId           String
  project             Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type                String
  name                String
  status              String           @default("draft")
  lifecycleYears      Int
  volume              Int              @default(0)
  installRatio        Float            @default(1)
  config              String           @default("{}")
  vehicleConfigs      String           @default("[]")
  configSkus          String           @default("[]")
  harnessConfigMappings String         @default("[]")
  vehicleConfigMeta   String           @default("{}")
  rateSnapshot        String           @default("{}")
  rateSnapshotVersion String?
  bomVersionRef       String?
  quoteParamSnapshot  String           @default("{}")
  sourceScenarioId    String?
  compareBaselineId   String?
  frozenAt            DateTime?
  releasedAt          DateTime?
  notes               String?
  createdBy           String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  simulations         SimulationTask[]
  annualDrops         AnnualDropRecord[]

  @@index([projectId])
  @@index([rateSnapshotVersion])
}

model Harness {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scenarioId  String?
  harnessId   String
  harnessName String

  input       String   @default("{}")
  result      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, scenarioId, harnessId])
  @@index([projectId, scenarioId])
}

model Quote {
  id                         String   @id @default(uuid())
  projectId                  String
  project                    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scenarioId                 String?
  harnessId                  String?
  version                    String
  status                     String   @default("draft")
  template                   String   @default("geely")
  data                       String   @default("{}")
  quoteParams                String   @default("{}")
  quoteResult                String   @default("{}")
  internalCostBaseline       Float    @default(0)
  profitGap                  Float    @default(0)
  exWorksPrice               Float    @default(0)
  arrivalPrice               Float    @default(0)
  effectivePrice             Float    @default(0)
  effectivePriceMode         String   @default("arrival")
  customerBurdenMode         String   @default("supplier_full")
  recoveryCompletionBehavior String   @default("notify_only")
  customerAccepted           Boolean  @default(false)
  lockedFields               String   @default("[]")
  editableFields             String   @default("[]")
  approvalFields             String   @default("[]")

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
  @@index([harnessId])
}

model AllocationItem {
  id                         String   @id @default(uuid())
  projectId                  String
  project                    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scenarioId                 String
  harnessId                  String
  expenseType                String
  expenseName                String
  totalAmount                Float    @default(0)
  allocationBasis            String?
  baselineVolume             Int      @default(0)
  unitAllocation             Float    @default(0)
  plannedRecovery            Float    @default(0)
  actualRecovered            Float    @default(0)
  remainingRecovery          Float    @default(0)
  recoveryProgress           Float    @default(0)
  burdenSide                 String   @default("supplier")
  pricingEffect              String   @default("internal_only")
  recoveryCompletionBehavior String   @default("notify_only")
  priceAdjustReminder        Boolean  @default(false)
  targetRecoveryDate         DateTime?
  completedAt                DateTime?
  status                     String   @default("pending")
  sourceVersionId            String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
  @@index([harnessId])
}

model RecoveryRecord {
  id                String   @id @default(uuid())
  allocationItemId  String
  projectId         String
  scenarioId        String
  period            String
  cumulativeVolume  Int      @default(0)
  installRatioSnapshot Float  @default(1)
  recoveredAmount   Float    @default(0)
  remainingAmount   Float    @default(0)
  status            String   @default("normal")
  remark            String?
  createdAt         DateTime @default(now())

  @@index([allocationItemId])
  @@index([projectId])
  @@index([scenarioId])
}

model ChangeEvent {
  id                String   @id @default(uuid())
  projectId         String
  scenarioId        String
  changeType        String
  reason            String?
  affectedHarnessIds String  @default("[]")
  affectedBomRows   String   @default("[]")
  costImpact        Float    @default(0)
  quoteImpact       Float    @default(0)
  residualImpact    Float    @default(0)
  baselineVersionId String?
  compareVersionId  String?
  status            String   @default("draft")
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
}

model TrackingItem {
  id            String   @id @default(uuid())
  projectId     String
  scenarioId    String
  trackingType  String
  title         String
  sourceRef     String?
  currentStatus String   @default("pending")
  severity      String   @default("medium")
  owner         String?
  plannedAction String?
  actualResult  String?
  closeReason   String?
  warningRef    String?
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
}

model ConnectorPricing {
  id                  String   @id @default(uuid())
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partNo              String
  partName            String
  supplier            String
  customerAgreedPrice Float    @default(0)
  supplierQuotedPrice Float    @default(0)
  finalNegotiatedPrice Float   @default(0)
  status              String   @default("pending")
  disputeReason       String?
  createdBy           String?
  approvedBy          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([projectId, partNo])
  @@index([projectId])
  @@index([status])
}

model WirePricing {
  id                 String   @id @default(uuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partNo             String
  partName           String
  supplier           String
  wireSize           String
  copperWeightG      Float    @default(0)
  aluminumWeightG    Float    @default(0)
  nonMetalCost       Float    @default(0)
  copperBasePrice    Float    @default(0)
  aluminumBasePrice  Float    @default(0)
  processingFee      Float    @default(0)
  calculatedPrice    Float    @default(0)
  validFrom          DateTime @default(now())
  validTo            DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([projectId, partNo])
  @@index([projectId])
}

model DevPartPricing {
  id                        String   @id @default(uuid())
  projectId                 String
  project                   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partNo                    String
  partName                  String
  category                  String
  amortizationQty           Int      @default(0)
  unitPriceWithAmortization Float    @default(0)
  unitPriceAfterAmortization Float   @default(0)
  lifecycleTotalQty         Int      @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  molds                     DevPartMold[]

  @@unique([projectId, partNo])
  @@index([projectId])
  @@index([category])
}

model DevPartMold {
  id               String         @id @default(uuid())
  devPartPricingId String
  devPartPricing   DevPartPricing @relation(fields: [devPartPricingId], references: [id], onDelete: Cascade)
  moldType         String
  moldName         String
  moldCost         Float          @default(0)
  isAmortized      Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([devPartPricingId])
}

model AuxiliaryPricing {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  partNo    String
  partName  String
  supplier  String
  unitPrice Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, partNo])
  @@index([projectId])
}

model PriceDiscrepancy {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenarioId     String?
  harnessId      String?
  partNo         String
  partName       String
  partCategory   String
  referencePrice Float    @default(0)
  actualPrice    Float    @default(0)
  discrepancy    Float    @default(0)
  discrepancyRate Float   @default(0)
  status         String   @default("open")
  resolutionType String?
  resolutionNote String?
  assignedTo     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
  @@index([status])
}

model Setting {
  id         String   @id @default(uuid())
  category   String
  key        String
  value      String   @default("{}")
  isGlobal   Boolean  @default(true)
  versionRef String?
  updatedBy  String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([category, key])
  @@index([category])
}

model SimulationTask {
  id                 String   @id @default(uuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenarioId         String
  scenario           Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  name               String
  status             String   @default("draft")
  parameterSnapshot  String   @default("{}")
  resultSnapshot     String   @default("{}")
  baselineScenarioId String?
  convertedScenarioId String?
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
}

model AnnualDropRecord {
  id                String   @id @default(uuid())
  projectId         String
  scenarioId        String
  scenario          Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  name              String
  status            String   @default("draft")
  year              Int
  dropRate          Float    @default(0)
  costBefore        Float    @default(0)
  costAfter         Float    @default(0)
  priceBefore       Float    @default(0)
  priceAfter        Float    @default(0)
  profitBefore      Float    @default(0)
  profitAfter       Float    @default(0)
  impactSummary     String   @default("{}")
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
}

model AlertRule {
  id          String   @id @default(uuid())
  name        String
  category    String
  severity    String   @default("warning")
  condition   String   @default("{}")
  enabled     Boolean  @default(true)
  description String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([severity])
  @@index([enabled])
}

model AlertEvent {
  id               String   @id @default(uuid())
  projectId        String
  scenarioId       String?
  ruleId           String?
  category         String
  severity         String   @default("warning")
  status           String   @default("active")
  title            String
  detail           String?
  sourceObjectType String?
  sourceObjectId   String?
  impactAmount     Float    @default(0)
  assignedTo       String?
  metadata         String   @default("{}")
  occurredAt       DateTime @default(now())
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
  @@index([category])
  @@index([severity])
  @@index([status])
  @@index([occurredAt])
}

model Version {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  versionNumber  Int
  label          String
  status         String   @default("draft")
  snapshot       String   @default("{}")
  notes          String?

  createdBy      String?
  createdAt      DateTime @default(now())

  @@unique([projectId, versionNumber])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  action      String
  entity      String
  entityId    String
  details     String?

  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}
