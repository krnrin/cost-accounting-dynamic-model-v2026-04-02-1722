generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  role       String   @default("ENGINEER") // ADMIN, MANAGER, ENGINEER, VIEWER
  feishuId   String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projects   Project[]
  auditLogs  AuditLog[]
}

model Project {
  id          String   @id @default(uuid())
  projectCode String   @unique
  projectName String
  customer    String
  platform    String?
  status      String   @default("active")

  costRates   String   @default("{}") // JSON string
  metalPrices String   @default("{}") // JSON string
  volumes     String?

  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scenarios   Scenario[]
  harnesses   Harness[]
  quotes      Quote[]
  allocations AllocationItem[]
  versions    Version[]
  auditLogs   AuditLog[]
}

model Scenario {
  id                 String   @id @default(uuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type               String
  name               String
  status             String   @default("draft")
  lifecycleYears     Int
  volume             Int      @default(0)
  installRatio       Float    @default(1)
  rateSnapshot       String   @default("{}")
  bomVersionRef      String?
  quoteParamSnapshot String   @default("{}")
  sourceScenarioId   String?
  compareBaselineId  String?
  frozenAt           DateTime?
  releasedAt         DateTime?
  notes              String?
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([projectId])
}

model Harness {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scenarioId  String?
  harnessId   String
  harnessName String

  input       String   @default("{}")
  result      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, harnessId])
}

model Quote {
  id                         String   @id @default(uuid())
  projectId                  String
  project                    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scenarioId                 String?
  harnessId                  String?
  version                    String
  status                     String   @default("draft")
  template                   String   @default("geely")
  data                       String   @default("{}")
  quoteParams                String   @default("{}")
  quoteResult                String   @default("{}")
  internalCostBaseline       Float    @default(0)
  profitGap                  Float    @default(0)
  exWorksPrice               Float    @default(0)
  arrivalPrice               Float    @default(0)
  effectivePrice             Float    @default(0)
  effectivePriceMode         String   @default("arrival")
  customerBurdenMode         String   @default("supplier_full")
  recoveryCompletionBehavior String   @default("notify_only")
  customerAccepted           Boolean  @default(false)
  lockedFields               String   @default("[]")
  editableFields             String   @default("[]")
  approvalFields             String   @default("[]")

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
  @@index([harnessId])
}

model AllocationItem {
  id                         String   @id @default(uuid())
  projectId                  String
  project                    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scenarioId                 String
  harnessId                  String
  expenseType                String
  expenseName                String
  totalAmount                Float    @default(0)
  allocationBasis            String?
  baselineVolume             Int      @default(0)
  unitAllocation             Float    @default(0)
  plannedRecovery            Float    @default(0)
  actualRecovered            Float    @default(0)
  remainingRecovery          Float    @default(0)
  recoveryProgress           Float    @default(0)
  burdenSide                 String   @default("supplier")
  pricingEffect              String   @default("internal_only")
  recoveryCompletionBehavior String   @default("notify_only")
  priceAdjustReminder        Boolean  @default(false)
  targetRecoveryDate         DateTime?
  completedAt                DateTime?
  status                     String   @default("pending")
  sourceVersionId            String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
  @@index([harnessId])
}

model RecoveryRecord {
  id                String   @id @default(uuid())
  allocationItemId  String
  projectId         String
  scenarioId        String
  period            String
  cumulativeVolume  Int      @default(0)
  installRatioSnapshot Float  @default(1)
  recoveredAmount   Float    @default(0)
  remainingAmount   Float    @default(0)
  status            String   @default("normal")
  remark            String?
  createdAt         DateTime @default(now())

  @@index([allocationItemId])
  @@index([projectId])
  @@index([scenarioId])
}

model ChangeEvent {
  id                String   @id @default(uuid())
  projectId         String
  scenarioId        String
  changeType        String
  reason            String?
  affectedHarnessIds String  @default("[]")
  affectedBomRows   String   @default("[]")
  costImpact        Float    @default(0)
  quoteImpact       Float    @default(0)
  residualImpact    Float    @default(0)
  baselineVersionId String?
  compareVersionId  String?
  status            String   @default("draft")
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
}

model TrackingItem {
  id            String   @id @default(uuid())
  projectId     String
  scenarioId    String
  trackingType  String
  title         String
  sourceRef     String?
  currentStatus String   @default("pending")
  severity      String   @default("medium")
  owner         String?
  plannedAction String?
  actualResult  String?
  closeReason   String?
  warningRef    String?
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
  @@index([scenarioId])
}

model Setting {
  id         String   @id @default(uuid())
  category   String
  key        String
  value      String   @default("{}")
  isGlobal   Boolean  @default(true)
  versionRef String?
  updatedBy  String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([category, key])
  @@index([category])
}

model Version {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  versionNumber  Int
  label          String
  status         String   @default("draft")
  snapshot       String   @default("{}")
  notes          String?

  createdBy      String?
  createdAt      DateTime @default(now())

  @@unique([projectId, versionNumber])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  action      String
  entity      String
  entityId    String
  details     String?

  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}
