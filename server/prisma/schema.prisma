generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  name       String
  role       String   @default("ENGINEER") // ADMIN, MANAGER, ENGINEER, VIEWER
  feishuId   String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projects   Project[]
  auditLogs  AuditLog[]
}

model Project {
  id          String   @id @default(uuid())
  projectCode String   @unique
  projectName String
  customer    String
  platform    String?
  status      String   @default("active")

  costRates   String   @default("{}") // JSON string
  metalPrices String   @default("{}") // JSON string
  volumes     String?

  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scenarios   Scenario[]
  harnesses   Harness[]
  quotes      Quote[]
  versions    Version[]
  auditLogs   AuditLog[]
}

model Scenario {
  id                 String   @id @default(uuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type               String
  name               String
  status             String   @default("draft")
  lifecycleYears     Int
  volume             Int      @default(0)
  installRatio       Float    @default(1)
  rateSnapshot       String   @default("{}")
  bomVersionRef      String?
  quoteParamSnapshot String   @default("{}")
  sourceScenarioId   String?
  compareBaselineId  String?
  frozenAt           DateTime?
  releasedAt         DateTime?
  notes              String?
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([projectId])
}

model Harness {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scenarioId  String?
  harnessId   String
  harnessName String

  input       String   @default("{}")
  result      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, harnessId])
}

model Quote {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  version     String
  status      String   @default("draft")
  template    String   @default("geely")
  data        String   @default("{}")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Version {
  id             String   @id @default(uuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  versionNumber  Int
  label          String
  status         String   @default("draft")
  snapshot       String   @default("{}")
  notes          String?

  createdBy      String?
  createdAt      DateTime @default(now())

  @@unique([projectId, versionNumber])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  action      String
  entity      String
  entityId    String
  details     String?

  createdAt   DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}
