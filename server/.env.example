# SQLite database file resolved relative to prisma/schema.prisma
DATABASE_URL="file:./data/harness_cost.db"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Auth
# Production must provide a strong secret.
JWT_SECRET=change-me-before-production
JWT_EXPIRES_IN=7d

# Feishu integration (optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
